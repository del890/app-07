# Required: Anthropic API key for the prediction service's LLM agent.
# Get one at https://console.anthropic.com/. Never commit the real value.
ANTHROPIC_API_KEY=

# Optional: environment name ("dev" | "staging" | "prod"). Default: dev
ENV=dev

# Optional: log level ("DEBUG" | "INFO" | "WARNING" | "ERROR"). Default: INFO
LOG_LEVEL=INFO

# Optional: path to the immutable dataset. Default: ../data.json (resolved from service/)
DATA_JSON_PATH=

# Optional: per-client rate limit on /v1/predictions/* (requests per minute). Default: 10
PREDICTIONS_RATE_LIMIT_PER_MINUTE=10

# Optional: monthly LLM spend cap in USD, surfaced in /v1/ready. Default: 50
LLM_MONTHLY_SPEND_CAP_USD=50

# Optional: calibration staleness threshold in days. Default: 14
CALIBRATION_STALE_AFTER_DAYS=14
