# Client (Nuxt) environment. Copy to `.env` for local development.

# Base URL the browser uses for API calls.
#
# Local dev: there is no nginx proxy, so point directly at the running service.
#   NUXT_PUBLIC_API_BASE=http://localhost:5000
#
# Production (Elastic Beanstalk): leave this UNSET. The app then issues relative
# `/v1/...` requests against the UI origin, where nginx proxies them to the
# backend (BACKEND_URL is configured on the UI EB environment, not here).
NUXT_PUBLIC_API_BASE=http://localhost:5000
